# Mars Rover Task Scheduler — Environment Variables
# Copy this file to .env and fill in your actual values.
# .env is git-ignored; this file (.env.example) is safe to commit.

# ── Required for inference.py (OpenEnv Submission Requirements) ───────────────

# Base URL for the OpenAI-compatible LLM API
# Groq:    https://api.groq.com/openai/v1
# OpenAI:  https://api.openai.com/v1
API_BASE_URL=https://api.groq.com/openai/v1

# Model identifier to use for inference
# Groq examples:  llama-3.1-8b-instant  |  mixtral-8x7b-32768
# OpenAI examples: gpt-4o-mini
MODEL_NAME=llama-3.1-8b-instant

# HuggingFace / API auth token — used as the api_key for LLM calls
# Get a free Groq key at: https://console.groq.com
HF_TOKEN=your_huggingface_token_here

# ── NASA Real-Time Data (optional) ────────────────────────────────────────────

# Free NASA API key — get yours at: https://api.nasa.gov
# Unlocks: InSight weather API, Mars Rover Photos API, Horizons ephemeris API
# Without this, physics-based fallback models are used automatically.
NASA_API_KEY=your_nasa_api_key_here

# ── Optional / Legacy ─────────────────────────────────────────────────────────

# Legacy alias for HF_TOKEN (still supported in baseline.py)
GROQ_API_KEY=your_groq_api_key_here


# Override the LLM model (used by baseline.py — inference.py uses MODEL_NAME)
BASELINE_MODEL=llama-3.1-8b-instant

# Override the environment base URL (default: http://localhost:7860)
ENV_BASE_URL=http://localhost:7860
